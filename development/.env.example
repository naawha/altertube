# piped | invidious — какой upstream использует Next API
BACKEND=piped

# Внешние инстансы (production на syllinn.me)
PIPED_INTERNAL_URL=https://api-video.syllinn.me
INVIDIOUS_INTERNAL_URL=https://invidious.syllinn.me

# Опционально: один URL вместо пары выше
# BACKEND_INTERNAL_URL=

# Порт nginx на хосте
HTTP_PORT=8080
